
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HoloprinterTools.PixelExposure.UI.ViewModels"
        xmlns:controls="clr-namespace:HoloprinterTools.PixelExposure.UI.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="HoloprinterTools.PixelExposure.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="HoloprinterTools.PixelExposure.UI">

  <TabControl>
    <TabItem Header="User Input">
      <Grid ColumnDefinitions="*,3*" RowDefinitions="Auto,*">
        <!-- Left panel with inputs -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Padding="12" BorderBrush="#FFE8E8E8" BorderThickness="0,0,1,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Width="220">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Default Settings" Width="120" Command="{Binding ShowSettingsCommand}"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Project Name:" FontSize="12" FontWeight="SemiBold"/>
                <TextBox Width="180" Text="{Binding Settings.Name, Mode=TwoWay}"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Length of Painting:" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="0" Value="{Binding Settings.Length, Mode=TwoWay}" Width="180" Increment="0.1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Width of Painting:" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="0" Value="{Binding Settings.Width, Mode=TwoWay}" Width="180" Increment="0.1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Height of Bottom of Painting:" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="0" Value="{Binding Settings.HeightOfBottomPainting, Mode=TwoWay}" Width="180" Increment="0.1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Height of Light Array (feet):" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="0" Value="{Binding Settings.HeightOfLightArray, Mode=TwoWay}" Width="180" Increment="0.1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Min Playback Wavelength (nm):" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="400" Maximum="700" Value="{Binding MinWavelength, Mode=TwoWay}" Width="180" Increment="1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Max Playback Wavelength (nm):" FontSize="12" FontWeight="SemiBold"/>
                <NumericUpDown Minimum="400" Maximum="700" Value="{Binding MaxWavelength, Mode=TwoWay}" Width="180" Increment="1"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Start" Width="85"/>
                <Button Content="Save" Width="85" Command="{Binding SaveCommand}"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- Right panel for visualization -->
        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Padding="12" Background="#FFF5F5F5">
          <StackPanel Spacing="12">
            <TextBlock Text="Visualization" FontSize="14" FontWeight="Bold" Foreground="#FF333333"/>
            <Border BorderThickness="1" BorderBrush="#FFD0D0D0" CornerRadius="4" Padding="12">
              <TextBlock Text="Results and visualizations will appear here" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
            </Border>
          </StackPanel>
        </Border>
      </Grid>
    </TabItem>

    <TabItem Header="Efficiency Curves">
      <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*,Auto">
        <!-- Left panel with inputs -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Padding="12" BorderBrush="#FFE8E8E8" BorderThickness="0,0,1,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Width="220">
              <TextBlock Text="Sweep Parameters" FontSize="12" FontWeight="SemiBold" Foreground="#FF333333"/>

              <StackPanel Spacing="4">
                <TextBlock Text="Start Wavelength (nm):" FontSize="11"/>
                <NumericUpDown Minimum="400" Maximum="900" Value="760" Width="200" Increment="1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Stop Wavelength (nm):" FontSize="11"/>
                <NumericUpDown Minimum="400" Maximum="900" Value="900" Width="200" Increment="1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Step Size (nm):" FontSize="11"/>
                <NumericUpDown Minimum="0.1" Maximum="50" Value="2" Width="200" Increment="0.1"/>
              </StackPanel>

              <Separator Background="#FFE0E0E0" Height="1" Margin="0,4"/>

              <TextBlock Text="Grating Parameters" FontSize="12" FontWeight="SemiBold" Foreground="#FF333333"/>

              <StackPanel Spacing="4">
                <TextBlock Text="Spatial Frequency:" FontSize="11"/>
                <NumericUpDown Minimum="100" Maximum="5000" Value="1200" Width="200" Increment="10"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Effective Thickness:" FontSize="11"/>
                <NumericUpDown Minimum="0.1" Maximum="100" Value="4" Width="200" Increment="0.1"/>
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Delta N:" FontSize="11"/>
                <NumericUpDown Minimum="0.001" Maximum="1" Value="0.112" Width="200" Increment="0.001"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Run Sweep" Width="105" Command="{Binding EfficiencyCurvesVM.RunWavelengthSweepCommand}"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- Right panel with chart -->
        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Orientation="Vertical" Spacing="8" Margin="12">
          <TextBlock Text="{Binding EfficiencyCurvesVM.Title}" FontSize="14" FontWeight="Bold" Foreground="#FF333333"/>
          <controls:LineChartControl DataPoints="{Binding EfficiencyCurvesVM.DataPoints}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
          <TextBlock Text="{Binding EfficiencyCurvesVM.StatusMessage}" Foreground="#FF666666" FontSize="11"/>
        </StackPanel>
      </Grid>
    </TabItem>
  </TabControl>

</Window>

