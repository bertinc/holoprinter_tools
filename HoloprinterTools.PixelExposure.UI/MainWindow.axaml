
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HoloprinterTools.PixelExposure.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="HoloprinterTools.PixelExposure.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="HoloprinterTools.PixelExposure.UI">

  <TabControl>
    <TabItem Header="User Input">
      <ScrollViewer>
        <StackPanel Margin="12" Spacing="8">
          <TextBlock Text="Enter parameters for the exposure process:"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Name:" VerticalAlignment="Center" Width="80"/>
            <TextBox Width="250" Text="{Binding Settings.Name, Mode=TwoWay}"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Slices:" VerticalAlignment="Center" Width="80"/>
            <NumericUpDown Minimum="1" Maximum="1000" Value="{Binding Settings.Slices, Mode=TwoWay}" Width="120"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Intensity:" VerticalAlignment="Center" Width="80"/>
            <Slider Minimum="0" Maximum="100" Value="{Binding Settings.Intensity, Mode=TwoWay}" Width="200"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start" Width="120" HorizontalAlignment="Left"/>
            <Button Content="Save" Width="120" HorizontalAlignment="Left" Command="{Binding SaveCommand}"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Efficiency Curves">
      <Grid Margin="12">
        <TextBlock Text="Efficiency curves will be shown here." VerticalAlignment="Top"/>
        <!-- Placeholder for chart or plot control. Replace with your plotting control later. -->
        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="4" Margin="0,24,0,0">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7">
            (Efficiency chart placeholder)
          </TextBlock>
        </Border>
      </Grid>
    </TabItem>
  </TabControl>

</Window>

