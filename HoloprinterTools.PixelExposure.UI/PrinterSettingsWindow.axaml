<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="clr-namespace:HoloprinterTools.PixelExposure.UI.ViewModels"
		mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
		x:Class="HoloprinterTools.PixelExposure.UI.PrinterSettingsWindow"
		x:DataType="vm:PrinterSettingsViewModel"
		Title="Printer Settings"
		WindowStartupLocation="CenterOwner"
		CanResize="False"
		Width="600"
		Height="700">

  <Grid RowDefinitions="*,Auto" Margin="12">
	<!-- ScrollViewer for the settings content -->
	<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
	  <StackPanel Spacing="16" Margin="0,0,12,0">
		<TextBlock Text="Printer Parameters" FontSize="18" FontWeight="Bold" Foreground="#FF333333"/>

		<!-- Printbed Dimensions Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Printbed Dimensions" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (mm):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding PrintbedWidth, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Length (mm):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding PrintbedLength, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Laser Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Laser Parameters" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" ColumnSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Wavelength (nm):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding LaserWavelength, Mode=TwoWay}" Width="200" Increment="1" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Beam 1 Angles Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Exposure Beam 1 Angles (degrees)" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Angle:" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Beam1MaxAngle, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="-180" Maximum="180"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Min Angle:" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Beam1MinAngle, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="-180" Maximum="180"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Beam 2 Angles Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Exposure Beam 2 Angles (degrees)" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Angle:" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Beam2MaxAngle, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="-180" Maximum="180"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Min Angle:" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Beam2MinAngle, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="-180" Maximum="180"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Pixel and Power Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Pixel and Beam Power" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Pixel Size (μm):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding PixelSize, Mode=TwoWay}" Width="200" Increment="0.01" Minimum="0"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Beam 1 Power (mW):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Beam1Power, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>

			  <TextBlock Grid.Row="2" Grid.Column="0" Text="Beam 2 Power (mW):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Beam2Power, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Settle Time Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Timing" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" ColumnSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Settle Time (ms):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SettleTime, Mode=TwoWay}" Width="200" Increment="1" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Efficiency and Delta-N Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Material Parameters" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Min Diffraction Eff. (%):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding MinDiffractionEfficiency, Mode=TwoWay}" Width="200" Increment="1" Minimum="0" Maximum="100"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Delta-N:" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MaxDeltaN, Mode=TwoWay}" Width="200" Increment="0.001" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>

		<!-- Viewing Parameters Section -->
		<Border BorderThickness="1" BorderBrush="#FFE0E0E0" CornerRadius="4" Padding="12">
		  <StackPanel Spacing="12">
			<TextBlock Text="Viewing Parameters" FontWeight="Bold" Foreground="#FF666666"/>

			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
			  <TextBlock Grid.Row="0" Grid.Column="0" Text="Nominal Viewing Height (feet):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding NominalViewingHeight, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>

			  <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum Viewing Distance (feet):" VerticalAlignment="Center" TextAlignment="Right"/>
			  <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MinimumViewingDistance, Mode=TwoWay}" Width="200" Increment="0.1" Minimum="0"/>
			</Grid>
		  </StackPanel>
		</Border>
	  </StackPanel>
	</ScrollViewer>

	<!-- Button Panel -->
	<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
	  <Button Name="OkButton" Content="OK" Width="80" IsDefault="True" Click="OkButton_Click"/>
	  <Button Name="CancelButton" Content="Cancel" Width="80" IsCancel="True" Click="CancelButton_Click"/>
	</StackPanel>
  </Grid>

</Window>
